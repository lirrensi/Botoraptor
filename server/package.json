{
    "name": "chat_layer_server",
    "version": "1.4.0",
    "description": "ChatLayer - human-in-the-loop conversation middleware",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "generate": "prisma generate",
        "migrate": "prisma migrate dev",
        "migrate:dev": "prisma migrate dev",
        "migrate:prod": "cross-env NODE_ENV=production prisma migrate deploy",
        "db:push": "prisma db push",
        "db:push:dev": "prisma db push",
        "db:push:prod": "cross-env NODE_ENV=production prisma db push",
        "db:seed": "tsx prisma/seed.ts",
        "db:seed:dev": "tsx prisma/seed.ts",
        "db:seed:prod": "cross-env NODE_ENV=production tsx prisma/seed.ts",
        "db:reset": "prisma migrate reset",
        "db:reset:dev": "prisma migrate reset",
        "db:reset:prod": "cross-env NODE_ENV=production prisma migrate reset",
        "start:prod": "cross-env NODE_ENV=production tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "test": "node --test dist/tests/server.test.js",
        "test:dev": "tsx --test tests/server.test.ts",
        "test:timeout_safe": "./run-tsx-test.bat"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.18.1",
    "dependencies": {
        "@prisma/adapter-better-sqlite3": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "body-parser": "^2.2.2",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "file-type": "^21.3.0",
        "multer": "^2.0.2",
        "node-fetch": "^3.3.2",
        "sqlite3": "^5.1.7",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.1.0",
        "@types/node-fetch": "^2.6.13",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "cross-env": "^10.1.0",
        "dotenv": "^17.2.3",
        "prisma": "^7.3.0",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
