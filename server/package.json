{
    "name": "chat_layer_server",
    "version": "1.4.0",
    "description": "Botoraptor - human-in-the-loop conversation middleware",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "generate": "npx prisma generate",
        "migrate": "npx prisma migrate dev",
        "migrate:dev": "npx prisma migrate dev",
        "migrate:prod": "cross-env NODE_ENV=production npx prisma migrate deploy",
        "db:push": "npx prisma db push",
        "db:push:dev": "npx prisma db push",
        "db:push:prod": "cross-env NODE_ENV=production npx prisma db push",
        "db:seed": "tsx prisma/seed.ts",
        "db:seed:dev": "tsx prisma/seed.ts",
        "db:seed:prod": "cross-env NODE_ENV=production tsx prisma/seed.ts",
        "db:reset": "npx prisma migrate reset",
        "db:reset:dev": "npx prisma migrate reset",
        "db:reset:prod": "cross-env NODE_ENV=production npx prisma migrate reset",
        "start:prod": "cross-env NODE_ENV=production tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "test": "node --test dist/tests/server.test.js",
        "test:dev": "tsx --test tests/server.test.ts",
        "test:timeout_safe": "./run-tsx-test.bat"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@11.13.1",
    "dependencies": {
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "body-parser": "^2.3.0",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "file-type": "^22.0.1",
        "helmet": "^8.3.0",
        "multer": "^2.2.0",
        "node-fetch": "^3.3.2",
        "sqlite3": "^6.0.1",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.2.0",
        "@types/node": "^26.1.1",
        "@types/node-fetch": "^3.0.2",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "prisma": "^7.8.0",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.23.1",
        "typescript": "^7.0.2"
    }
}
