# ChatLayer Environment Variables
# Copy this file to .env and update with your values

# Database URLs - Prisma will pick based on NODE_ENV
DATABASE_URL_DEV="file:./db/dev.db"
DATABASE_URL_PROD="file:./db/main.db"

# Required: Secret key for signing file upload URLs
# Generate a strong random string for production
FILE_SIGNING_SECRET=change-me-in-production-use-a-strong-random-string

