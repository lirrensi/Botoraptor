{
    "name": "chat_layer_web_ui",
    "private": true,
    "version": "1.4.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc && vite build",
        "postbuild": "node -e \"const fs=require('fs'),path=require('path');const publicDir='../server/public';if(fs.existsSync(publicDir)){fs.rmSync(publicDir,{recursive:true});}fs.mkdirSync(publicDir,{recursive:true});for(const f of fs.readdirSync('dist')) fs.cpSync(path.join('dist',f), path.join(publicDir,f), {recursive:true});\"",
        "preview": "vite preview",
        "test:e2e": "cypress run",
        "test:unit": "vitest",
        "lint": "eslint ."
    },
    "dependencies": {
        "@ionic/vue": "^8.8.14",
        "@ionic/vue-router": "^8.8.14",
        "axios": "^1.18.1",
        "fuse.js": "^7.5.0",
        "ionicons": "^8.0.13",
        "localforage": "^1.10.0",
        "luxon": "^3.7.2",
        "pinia": "^4.0.2",
        "timeago.js": "^4.0.2",
        "vue": "^3.5.40",
        "vue-highlight-words": "^3.0.1",
        "vue-i18n": "^11.4.6",
        "vue-router": "^5.2.0"
    },
    "devDependencies": {
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.1.1",
        "@vitejs/plugin-legacy": "^8.2.1",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vue/eslint-config-typescript": "^14.9.0",
        "jsdom": "^29.1.1",
        "terser": "^5.49.0",
        "typescript": "~7.0.2",
        "vite": "~8.1.5",
        "vue-tsc": "^3.3.7"
    },
    "overrides": {
        "rollup": "4.44.0"
    }
}
