{
    "name": "chat_layer_web_ui",
    "private": true,
    "version": "1.4.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc && vite build",
        "postbuild": "node -e \"const fs=require('fs'),path=require('path');const publicDir='../server/public';if(fs.existsSync(publicDir)){fs.rmSync(publicDir,{recursive:true});}fs.mkdirSync(publicDir,{recursive:true});for(const f of fs.readdirSync('dist')) fs.cpSync(path.join('dist',f), path.join(publicDir,f), {recursive:true});\"",
        "preview": "vite preview",
        "test:e2e": "cypress run",
        "test:unit": "vitest",
        "lint": "eslint ."
    },
    "dependencies": {
        "@ionic/vue": "^8.7.17",
        "@ionic/vue-router": "^8.7.17",
        "axios": "^1.13.4",
        "fuse.js": "^7.1.0",
        "ionicons": "^8.0.13",
        "localforage": "^1.10.0",
        "luxon": "^3.7.2",
        "pinia": "^3.0.4",
        "timeago.js": "^4.0.2",
        "vue": "^3.5.27",
        "vue-highlight-words": "^3.0.1",
        "vue-i18n": "^11.2.8",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.1.0",
        "@vitejs/plugin-legacy": "^7.2.1",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vue/eslint-config-typescript": "^14.6.0",
        "jsdom": "^27.4.0",
        "terser": "^5.46.0",
        "typescript": "~5.9.3",
        "vite": "~7.3.1",
        "vue-tsc": "^3.2.4"
    },
    "overrides": {
        "rollup": "4.44.0"
    }
}
