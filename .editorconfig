# EditorConfig - consistent coding style across editors
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript/JavaScript (server, web_ui, node SDK)
[*.{ts,tsx,js,jsx,json}]
indent_style = space
indent_size = 2

# Python SDK
[*.py]
indent_style = space
indent_size = 4

# Prisma schema
[*.prisma]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Makefiles (require tabs)
[Makefile]
indent_style = tab
